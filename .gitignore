# ==============================================================================
# 🔒 Security & Secrets (最重要：ここだけは絶対死守)
# ==============================================================================
# ローカル固有の設定ファイル (会社用のAPIキーなどはここに書く)
.zshrc.local
.bashrc.local
*.local
.env
.env.*

# SSH鍵・認証情報 (万が一フォルダ内に置いても無視させる)
.ssh/
id_rsa
id_ed25519
*.pem
*.key
*.p12
*.pub

# クラウドベンダーの認証ファイル
.aws/
.azure/
.gcp/
.config/gcloud/

# ==============================================================================
# 📜 History Files (コマンド履歴にはパスワードが含まれる可能性がある)
# ==============================================================================
.zsh_history
.bash_history
.history
.python_history
.mysql_history
.lesshst
.wget-hsts

# ==============================================================================
# 🗑 System & Editor Junk (OS/エディタのゴミ)
# ==============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*

# Editor (VS Code, JetBrains, Vim)
.vscode/
.idea/
*.swp
*.swo
*.swn

# ==============================================================================
# 📦 Others
# ==============================================================================
# ログファイル
*.log

# バックアップファイル
*.bak
*.backup
*.old
*.orig